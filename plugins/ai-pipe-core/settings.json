{
  "$comment": "ai-pipe-core plugin hook wiring. ${CLAUDE_PLUGIN_DIR} resolves to the plugin's cached location regardless of install path. Requires jq, gh, bash, git on PATH. PreToolUse hooks exit 2 to block (Claude Code convention); SessionStart stdout is injected into context; Stop hook is best-effort and never blocks session end.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/hooks/verify-boundary.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/hooks/secrets-scan.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/hooks/verify-git-safety.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/hooks/validate-commit-msg.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/hooks/ban-background.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/hooks/secrets-scan.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/hooks/validate-subagent-type.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DIR}/hooks/stop-checkpoint.sh"
          }
        ]
      }
    ]
  }
}
