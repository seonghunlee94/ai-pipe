#!/usr/bin/env bash
# adp-watch — spec §12.2 + PR6 observability
# Real-time pipeline event viewer over .artifacts/runs/{slug}-events.jsonl.
# Pretty-prints phase/task/retry/escalation events and keeps a running
# token + cost total when events carry a `usage` object.
#
# Usage:
#   adp-watch <slug>            # follow live (tail -f)
#   adp-watch <slug> --replay   # print existing events once and exit (no follow)
#   adp-watch --cost <slug>     # print only the cost/token summary and exit

set -uo pipefail   # no -e: a malformed JSONL line must not kill the viewer

if ! command -v jq >/dev/null 2>&1; then
  echo "adp-watch requires jq. Install with: brew install jq / apt install jq" >&2
  exit 78   # EX_CONFIG
fi

MODE="follow"
SLUG=""
for arg in "$@"; do
  case "$arg" in
    --replay) MODE="replay" ;;
    --cost)   MODE="cost" ;;
    --*)      echo "Unknown flag: $arg" >&2; exit 64 ;;
    *)        SLUG="$arg" ;;
  esac
done

if [[ -z "$SLUG" ]]; then
  echo "Usage: adp-watch <slug> [--replay|--cost]" >&2
  exit 64   # EX_USAGE
fi

EVENTS_FILE=".artifacts/runs/${SLUG}-events.jsonl"
if [[ ! -f "$EVENTS_FILE" ]]; then
  echo "No events yet at $EVENTS_FILE" >&2
  exit 66   # EX_NOINPUT
fi

# Per-model USD/1M-token rates handled inside awk (print_cost_summary).
# ESTIMATES as of 2026-06 — verify at docs.anthropic.com/en/docs/about-claude/pricing
# before relying on cost figures (README §6: cost accuracy is empirically unverified).
#   Opus 4.x  $15 / $75     Sonnet 4.x  $3 / $15     Haiku 4.5  $1 / $5
# Cache reads bill at ~10% of input; cache writes at ~125% (5-min TTL).
# Unknown models contribute 0 cost (tokens still counted).

print_event() {
  local line="$1"
  # Extract every displayed field in ONE jq call (avoids ~6 forks/line on the
  # live path). A partial/invalid line yields no output and is skipped.
  local fields
  fields=$(jq -r '[.ts // "?", .type // "?", (.phase // "?"|tostring),
                   .task_id // "?", .agent // "?", .status // "?",
                   (.attempt // "?"|tostring), .category // "?",
                   .to // "human", .branch // "?",
                   (.dirty_files // 0|tostring)] | @tsv' <<<"$line" 2>/dev/null) || return 0
  local ts type phase task_id agent status attempt category to branch dirty
  IFS=$'\t' read -r ts type phase task_id agent status attempt category to branch dirty <<<"$fields"
  case "$type" in
    phase_start)  printf '[%s] ▶ Phase %s started\n'   "$ts" "$phase" ;;
    phase_done)   printf '[%s] ✔ Phase %s done\n'       "$ts" "$phase" ;;
    task_start)   printf '[%s]   ▶ %s (%s)\n'           "$ts" "$task_id" "$agent" ;;
    task_done)    printf '[%s]   ✔ %s %s\n'             "$ts" "$task_id" "$status" ;;
    task_retry)   printf '[%s]   ⚠ %s retry #%s (%s)\n' "$ts" "$task_id" "$attempt" "$category" ;;
    escalation)   printf '[%s]   ✗ %s ESCALATED → %s\n' "$ts" "$task_id" "$to" ;;
    session_stop) printf '[%s] ⏹ session stop (branch %s, %s dirty)\n' "$ts" "$branch" "$dirty" ;;
    *)            printf '[%s]   · %s\n' "$ts" "$type" ;;
  esac
}

print_cost_summary() {
  # Aggregate usage across all events in a SINGLE awk pass. Each event may
  # carry .usage.{model,input_tokens,output_tokens,cache_read_tokens,
  # cache_creation_tokens}. jq emits one TSV row per usage-bearing event;
  # awk does all arithmetic (token counts AND cost — float-safe, no bash
  # integer overflow/abort) under LC_ALL=C so a comma-decimal locale can't
  # corrupt totals. Rate table lives here as the single source of truth.
  # `-R fromjson?` parses each line independently and DROPS malformed lines
  # (a plain `jq -r . file` would abort the whole pass at the first bad line).
  jq -rR 'fromjson? | select(type=="object" and .usage) | [.usage.model // "unknown",
         (.usage.input_tokens // 0), (.usage.output_tokens // 0),
         (.usage.cache_read_tokens // 0), (.usage.cache_creation_tokens // 0)]
         | @tsv' "$EVENTS_FILE" 2>/dev/null \
  | LC_ALL=C awk -F'\t' -v slug="$SLUG" '
      function rate(m,   r) {
        if (m ~ /opus/)        r="15 75";
        else if (m ~ /sonnet/) r="3 15";
        else if (m ~ /haiku/)  r="1 5";
        else                   r="0 0";
        return r;
      }
      {
        split(rate($1), p, " "); ri=p[1]+0; ro=p[2]+0;
        in_t += $2; out_t += $3;
        cost += ($2*ri + $3*ro + $4*ri*0.1 + $5*ri*1.25) / 1000000;
      }
      END {
        printf "── cost summary (%s) ──\n", slug;
        printf "  input tokens:  %d\n", in_t;
        printf "  output tokens: %d\n", out_t;
        printf "  est. cost:     $%.6f USD\n", cost;
      }'
}

case "$MODE" in
  cost)
    print_cost_summary
    ;;
  replay)
    while IFS= read -r line; do print_event "$line"; done < "$EVENTS_FILE"
    echo "──"
    print_cost_summary
    ;;
  follow)
    # Print backlog, then follow. Cost summary is available via --cost.
    while IFS= read -r line; do print_event "$line"; done < "$EVENTS_FILE"
    tail -n0 -f "$EVENTS_FILE" | while IFS= read -r line; do print_event "$line"; done
    ;;
esac
