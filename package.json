{
  "name": "@seonghunlee94/ai-pipe",
  "version": "0.1.0",
  "description": "Multi-agent automation pipeline CLI for Claude Code. Scaffolding stage — see README for status.",
  "type": "module",
  "bin": {
    "ai-pipe": "dist/cli.js"
  },
  "files": [
    "dist",
    "template",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "npm run lint && npm run typecheck && npm run test:unit && npm run test:hooks && npm run test:scripts",
    "lint": "biome check src --error-on-warnings",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "test:unit": "vitest run",
    "test:hooks": "bash test/hooks/run.sh",
    "test:scripts": "bash test/scripts/run.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "author": "seonghunlee94",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seonghunlee94/ai-pipe.git"
  },
  "bugs": {
    "url": "https://github.com/seonghunlee94/ai-pipe/issues"
  },
  "homepage": "https://github.com/seonghunlee94/ai-pipe#readme",
  "keywords": [
    "claude-code",
    "multi-agent",
    "pipeline",
    "orchestration"
  ],
  "license": "MIT",
  "private": false
}
