{
  "name": "@your-org/ai-pipe",
  "version": "0.0.1",
  "description": "Multi-agent automation pipeline CLI for Claude Code. Scaffolding stage — see README for status.",
  "type": "module",
  "bin": {
    "ai-pipe": "dist/cli.js"
  },
  "files": [
    "dist",
    "template",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "npm run typecheck && npm run test:unit && npm run test:hooks",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "test:unit": "vitest run",
    "test:hooks": "bash test/hooks/run.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/ai-pipe.git"
  },
  "keywords": [
    "claude-code",
    "multi-agent",
    "pipeline",
    "orchestration"
  ],
  "license": "UNLICENSED",
  "private": false
}
