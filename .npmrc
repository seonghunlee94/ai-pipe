# Route the @seonghunlee94 scope to GitHub Packages (spec §13.1).
# (Forking under your own org? Replace @seonghunlee94 with your GitHub org/user.)
# Authentication: put your PAT in ~/.npmrc, NOT here. Example for ~/.npmrc:
#   //npm.pkg.github.com/:_authToken=ghp_xxxxxxxxxxxxxxxxxxxx
@seonghunlee94:registry=https://npm.pkg.github.com
